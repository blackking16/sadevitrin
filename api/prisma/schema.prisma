generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum Category {
  PET
  BABY
}

enum AuctionStatus {
  DRAFT
  OPEN
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  CARD
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  id           String      @id @default(cuid())
  role         UserRole
  name         String
  phone        String      @unique
  email        String      @unique
  passwordHash String
  isPhoneVerified Boolean  @default(false)
  isEmailVerified Boolean  @default(false)
  experienceMode String     @default("SIMPLE")
  notifyOrderUpdates Boolean @default(true)
  notifyReorderReminders Boolean @default(true)
  notifySavedItemUpdates Boolean @default(true)
  notifySearchDemandUpdates Boolean @default(true)
  notifyNewProducts Boolean @default(false)
  notifyCampaigns Boolean @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  sellerProfile SellerProfile?
  addresses     Address[]
  carts         CartItem[]
  orders        Order[]
  reviews       Review[]
  savedItems    SavedItem[]
  productRequests ProductRequest[]
  bids          Bid[]
  products      Product[]
  notifications Notification[]
  complaints    Complaint[]
  searchDemands SearchDemand[]
  barcodeDemands BarcodeDemand[]
  influencerProfile InfluencerProfile?
  influencerFollows InfluencerFollow[]
  vitrinProducts InfluencerProduct[]
}

model SellerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  taxNumber   String
  status      String   @default("PENDING")
  sellInSimple Boolean  @default(true)
  sellInVitrin Boolean  @default(true)
  rating      Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  title     String
  city      String
  district  String
  detail    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]
}

model ProductRequest {
  id          String   @id @default(cuid())
  sellerId    String
  category    Category
  categoryName String   @default("Pet")
  subCategoryName String?
  segmentName String?
  petType     String?
  petSubCategory String?
  babySubCategory String?
  brand       String
  model       String
  packageInfo String
  barcode     String?
  imageUrl    String?
  description String
  status      String   @default("REQUESTED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller  User      @relation(fields: [sellerId], references: [id])
  auction Auction?
}

model Auction {
  id          String        @id @default(cuid())
  requestId   String        @unique
  startsAt    DateTime      @default(now())
  endsAt      DateTime
  status      AuctionStatus @default(OPEN)
  winnerBidId String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  request   ProductRequest @relation(fields: [requestId], references: [id])
  bids      Bid[]
  winnerBid Bid?           @relation("WinningBid", fields: [winnerBidId], references: [id])
  product   Product?
}

model Bid {
  id           String   @id @default(cuid())
  auctionId    String
  sellerId     String
  price        Decimal
  stock        Int
  deliveryDays Int
  note         String?
  createdAt    DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id])
  seller  User    @relation(fields: [sellerId], references: [id])
  wonAuction Auction? @relation("WinningBid")
}

model Product {
  id           String   @id @default(cuid())
  auctionId    String   @unique
  sellerId     String
  category     Category
  categoryName String   @default("Pet")
  subCategoryName String?
  segmentName String?
  petType      String?
  petSubCategory String?
  babySubCategory String?
  title        String
  barcode      String?  @unique
  imageUrl     String?
  description  String
  price        Decimal
  stock        Int
  deliveryDays Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auction Auction @relation(fields: [auctionId], references: [id])
  seller  User    @relation(fields: [sellerId], references: [id])
  cartItems CartItem[]
  orderItems OrderItem[]
  reviews Review[]
  savedItems SavedItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  userId        String
  addressId     String
  status        OrderStatus   @default(PREPARING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  subtotal      Decimal
  total         Decimal
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  address Address     @relation(fields: [addressId], references: [id])
  items   OrderItem[]
  payment Payment?
  shipment Shipment?
  returns ReturnRequest[]
  reviews Review[]
  savedItems SavedItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  sellerId  String
  title     String
  imageUrl   String?
  quantity  Int
  unitPrice Decimal
  total     Decimal

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id             String        @id @default(cuid())
  orderId        String        @unique
  provider       String
  providerRef    String?
  method         PaymentMethod
  status         PaymentStatus
  amount         Decimal
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model Shipment {
  id             String   @id @default(cuid())
  orderId        String   @unique
  carrier        String?
  trackingNumber String?
  status         String   @default("PREPARING")
  shippedAt      DateTime?
  deliveredAt    DateTime?

  order Order @relation(fields: [orderId], references: [id])
}

model Review {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  userId       String
  productRating Int
  sellerRating  Int
  comment      String
  createdAt    DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([orderId, productId, userId])
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  productId String?
  orderId   String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])
}

model ReturnRequest {
  id        String       @id @default(cuid())
  orderId   String
  userId    String
  reason    String
  status    ReturnStatus @default(REQUESTED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Complaint {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model SearchDemand {
  id              String   @id @default(cuid())
  userId          String?
  query           String
  normalizedQuery String
  resultCount     Int      @default(0)
  category        Category?
  categoryName    String?
  subCategoryName String?
  segmentName     String?
  petType         String?
  petSubCategory  String?
  babySubCategory String?
  status          String   @default("OPEN")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model BarcodeDemand {
  id        String   @id @default(cuid())
  userId    String?
  barcode   String
  note      String?
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([barcode])
  @@index([status, createdAt])
}

model InfluencerProfile {
  id            String   @id @default(cuid())
  ownerId       String?  @unique
  name          String
  handle        String   @unique
  specialty     String
  bio           String
  avatarUrl     String
  heroUrl       String
  followerCount Int      @default(0)
  verified      Boolean  @default(false)
  status        String   @default("PUBLISHED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner       User?                  @relation(fields: [ownerId], references: [id])
  posts       InfluencerPost[]
  products    InfluencerProduct[]
  collections InfluencerCollection[]
  follows     InfluencerFollow[]
}

model InfluencerPost {
  id            String   @id @default(cuid())
  influencerId  String
  productId     String?
  type          String
  title         String
  caption       String
  mediaUrl      String
  mediaUrls     String[] @default([])
  productTitle  String
  productQuery  String
  productPrice  String
  campaign      String?
  tags          String[]
  productLinks  Json?
  likeCount     Int      @default(0)
  commentCount  Int      @default(0)
  dailyScore    Int      @default(0)
  weeklyScore   Int      @default(0)
  monthlyScore  Int      @default(0)
  status        String   @default("PUBLISHED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])
  product    InfluencerProduct? @relation(fields: [productId], references: [id])
  likes      InfluencerPostLike[]
  comments   InfluencerPostComment[]
  insight    InfluencerContentInsight?

  @@index([dailyScore])
  @@index([weeklyScore])
  @@index([monthlyScore])
  @@index([type])
}

model InfluencerContentInsight {
  id               String   @id @default(cuid())
  postId           String   @unique
  category         String
  subCategory      String?
  tags             String[] @default([])
  targetAudience   String[] @default([])
  summary          String
  qualityScore     Int      @default(50)
  commercialIntent Int      @default(50)
  risk             String   @default("low")
  algorithmScore   Int      @default(0)
  model            String?
  raw              Json?
  analyzedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  post InfluencerPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([algorithmScore])
}

model InfluencerPostLike {
  id        String   @id @default(cuid())
  postId    String
  profileId String
  createdAt DateTime @default(now())

  post InfluencerPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, profileId])
  @@index([profileId])
}

model InfluencerPostComment {
  id        String   @id @default(cuid())
  postId    String
  profileId String
  text      String
  createdAt DateTime @default(now())

  post InfluencerPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([profileId])
}

model InfluencerProduct {
  id           String   @id @default(cuid())
  influencerId String?
  sellerId     String?
  title        String
  description  String
  imageUrl     String
  imageUrls    String[] @default([])
  priceText    String
  sellerName   String   @default("Vitrin satıcısı")
  detailText   String?
  sizes        String[] @default([])
  colors       String[] @default([])
  linkText     String?
  stockText    String?
  dailyHits    Int      @default(0)
  weeklyHits   Int      @default(0)
  monthlyHits  Int      @default(0)
  status       String   @default("PUBLISHED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  influencer InfluencerProfile? @relation(fields: [influencerId], references: [id])
  seller     User? @relation(fields: [sellerId], references: [id])
  posts      InfluencerPost[]

  @@index([influencerId, status])
  @@index([sellerId, status])
  @@index([dailyHits])
  @@index([weeklyHits])
  @@index([monthlyHits])
}

model InfluencerCollection {
  id           String   @id @default(cuid())
  influencerId String
  title        String
  text         String
  productCount Int      @default(0)
  mediaUrl      String
  status       String   @default("PUBLISHED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])
}

model InfluencerFollow {
  id           String   @id @default(cuid())
  profileId    String
  influencerId String
  createdAt    DateTime @default(now())

  user       User              @relation(fields: [profileId], references: [id])
  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@unique([profileId, influencerId])
}
